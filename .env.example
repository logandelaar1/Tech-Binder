# APS Model URN — base64url-encoded object ID of the translated Fusion model (safe to expose)
VITE_APS_MODEL_URN=

# Cloudflare Worker Token Endpoint
# Set this to your deployed Cloudflare Worker URL (e.g., https://team5000-aps-token.workers.dev)
# For local development with `wrangler dev`, use http://localhost:8787
VITE_APS_TOKEN_ENDPOINT=http://localhost:8787

# Cloudflare Worker Credentials (only needed for running `wrangler dev`)
APS_CLIENT_ID=
APS_CLIENT_SECRET=
